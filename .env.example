# ─── Discord Bot ─────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_OWNER_ID=your_discord_user_id

# ─── Database (MongoDB) ─────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/gapat

# ─── Dashboard ───────────────────────────────────────────────────
DASHBOARD_PORT=4567
DASHBOARD_SECRET=generate_a_random_string_at_least_32_chars_long
DASHBOARD_URL=http://localhost:4567

# ─── Bot API (internal, dashboard <-> bot) ──────────────────────
BOT_API_PORT=3001
INTERNAL_API_SECRET=generate_a_random_string_at_least_16_chars_long

# ─── Encryption (AES-256, 64 hex chars = 32 bytes) ──────────────
ENCRYPTION_KEY=generate_64_random_hex_characters_for_aes256_encryption_key

# ─── Optional: Branding ──────────────────────────────────────────
# BRAND_NAME=Gapat Bot
# LOGO_URL=

# ─── Optional: AI Defaults ───────────────────────────────────────
# AI_MODEL=gemma4:31b-cloud
# AI_TEMPERATURE=0.7
# AI_MAX_TOKENS=2048
