<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gapat Bot — Dashboard</title>
<link rel="icon" href="/img/favicon.ico" type="image/x-icon">
<link rel="stylesheet" href="/css/style.css">
<script src="https://cdn.tailwindcss.com"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');</style>
</head>
<body class="min-h-screen" style="background:var(--bg-base);color:var(--text-primary)" x-data="dashboardData()" x-init="init(); $store.user.init()" >
 <script src="/js/app.js"></script>

 <%- include('partials/sidebar') %>

 <!-- Main content -->
 <div class="main-content min-h-screen flex flex-col" :class="{ 'full': !$store.app.sidebarOpen }">
 <!-- Header -->
 <header class="sticky top-0 z-30 px-4 md:px-8 py-4 flex items-center gap-4" style="background:var(--header-bg);border-bottom:1px solid var(--border-color);backdrop-filter:blur(12px)">
 <button @click="$store.app.toggleSidebar()" class="p-2 -ml-2 rounded-lg" style="color:var(--text-muted);background:var(--bg-elevated)">
 <i class="fas fa-bars text-xl"></i>
 </button>
 <h1 class="text-xl font-bold" style="color:var(--text-primary)">Dashboard</h1>
 <div class="ml-auto flex items-center gap-3 text-sm" style="color:var(--text-muted)">
 <template x-if="$store.user.avatar">
 <img :src="$store.user.avatar" class="w-7 h-7 rounded-full" :alt="$store.user.username">
 </template>
 <span class="hidden sm:inline font-medium" x-text="$store.user.username"></span>
 <span class="hidden sm:inline">·</span>
 <i class="fas fa-circle text-emerald-400 text-xs"></i>
 <span class="hidden sm:inline">Online</span>
 <span x-show="$store.user.role === 'owner'" class="px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(99,102,241,0.2);color:#818cf8">Owner</span>
 <span x-show="$store.user.role === 'admin'" class="px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(245,158,11,0.2);color:#f59e0b">Admin</span>
 </div>
 </header>

 <!-- Content -->
 <div class="p-4 md:p-8 flex-1">
 <!-- Error -->
 <div x-show="error" x-text="error" class="border border-[var(--border-rose)] px-5 py-3 rounded-xl mb-6" style="display:none"></div>

 <!-- Loading -->
 <div x-show="loading" class="flex items-center justify-center py-20" style="color:var(--text-muted);display:none">
 <i class="fas fa-spinner fa-spin text-2xl mr-3"></i>
 <span>Loading data...</span>
 </div>

 <!-- Stats cards -->
 <div x-show="!loading" class="grid grid-cols-2 lg:grid-cols-3 gap-4" >
 <template x-for="(card, i) in cards" :key="i">
 <div class="stat-card rounded-xl p-5 border cursor-default fade-in" :style="'animation-delay:'+(i*60)+'ms'" :class="card.bg">
 <div class="flex items-center justify-between mb-3">
 <span class="text-xs font-medium uppercase tracking-wide" style="color:var(--text-muted)" x-text="card.label"></span>
 <i :class="'text-lg '+card.icon" :style="'color:'+card.iconColor"></i>
 </div>
 <p class="text-3xl font-extrabold" style="color:var(--text-primary)" x-text="fmt(card.value)"></p>
 </div>
 </template>
 </div>
 </div>

 <!-- Footer -->
 <footer class="px-4 md:px-8 py-4 flex items-center justify-between text-xs" style="border-color:var(--border-color);background:var(--bg-surface);color:var(--text-muted)">
 <span>&copy; 2026 Gapat Bot</span>
 <span x-data="healthFooter()" x-init="init()">
 <template x-if="health === null">
 <span><i class="fas fa-spinner fa-spin mr-1"></i>Checking API...</span>
 </template>
 <template x-if="health === true">
 <span><i class="fas fa-circle text-emerald-400 text-[8px] mr-1"></i>API Online</span>
 </template>
 <template x-if="health === false">
 <span><i class="fas fa-circle text-red-400 text-[8px] mr-1"></i>API Offline</span>
 </template>
 </span>
 </footer>
 </div>

 <script>
 function dashboardData() {
 return {
 loading: true,
 error: '',
 path: window.location.pathname,
 cards: [],
 async init() {
 try {
 const d = await API.get('/api/v1/analytics/overview');
 this.cards = [
 { label:'Total Servers', value:d.guilds ||0, icon:'fas fa-server', iconColor:'#818cf8', bg:'' },
 { label:'Active Channels', value:d.channels ||0, icon:'fas fa-hashtag', iconColor:'#34d399', bg:'' },
 { label:'Total Messages', value:d.totalMessages||0, icon:'fas fa-comments', iconColor:'#fbbf24', bg:'' },
 { label:'Total Tokens', value:d.totalTokens ||0, icon:'fas fa-coins', iconColor:'#f87171', bg:'' },
 { label:'Total Users', value:d.totalUsers ||0, icon:'fas fa-users', iconColor:'#a78bfa', bg:'' },
 { label:'Active Providers', value:d.providers ||0, icon:'fas fa-plug', iconColor:'#22d3ee', bg:'' },
 ];
 } catch(e) {
 const msg = e?.message || 'Failed to load dashboard data';
 this.error = '❌ ' + msg;
 showToast(msg, 'error');
 } finally {
 this.loading = false;
 }
 }
 };
 }

 </script>
</body>
</html>
