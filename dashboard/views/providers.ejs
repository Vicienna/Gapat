<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gapat Bot — Providers</title>
<link rel="icon" href="/img/favicon.ico" type="image/x-icon">
<link rel="stylesheet" href="/css/style.css">
<script src="https://cdn.tailwindcss.com"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');</style>
</head>
<body class="min-h-screen" style="background:var(--bg-base);color:var(--text-primary)" x-data="providersData()" x-init="init(); $store.user.init()" >
<script src="/js/app.js"></script>

<%- include('partials/sidebar') %>

<div class="main-content min-h-screen flex flex-col" :class="{ 'full': !$store.app.sidebarOpen }">
 <header class="sticky top-0 z-30 px-4 md:px-8 py-4 flex items-center gap-4" style="background:var(--header-bg);border-bottom:1px solid var(--border-color);backdrop-filter:blur(12px)">
 <button @click="$store.app.toggleSidebar()" class="p-2 -ml-2 rounded-lg" style="color:var(--text-muted);background:var(--bg-elevated)">
 <i class="fas fa-bars text-xl"></i>
 </button>
 <h1 class="text-xl font-bold" style="color:var(--text-primary)">Providers</h1>
 <div class="ml-auto flex items-center gap-3 text-sm" style="color:var(--text-secondary)">
 <template x-if="$store.user.avatar">
 <img :src="$store.user.avatar" class="w-7 h-7 rounded-full" :alt="$store.user.username">
 </template>
 <span class="hidden sm:inline font-medium" x-text="$store.user.username"></span>
 <span class="hidden sm:inline" style="color:var(--text-muted)">·</span>
 <i class="fas fa-circle text-emerald-400 text-xs"></i>
 <span class="hidden sm:inline">Online</span>
 <span x-show="$store.user.role === 'owner'" class="px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(99,102,241,0.2);color:#818cf8">Owner</span>
 <span x-show="$store.user.role === 'admin'" class="px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(245,158,11,0.2);color:#f59e0b">Admin</span>
 </div>
 </header>

 <div class="p-4 md:p-8 flex-1">
 <div x-show="error" x-text="error" class="border border-[var(--border-rose)] px-5 py-3 rounded-xl mb-6" style="display:none"></div>

  <div x-show="loading" class="space-y-4" style="display:none">
 <template x-for="i in 4" :key="i">
 <div class="rounded-xl p-5 animate-pulse" style="background:var(--bg-surface);border:1px solid var(--border-color)">
 <div class="flex items-center gap-4">
 <div class="w-12 h-12 rounded-full" style="background:var(--bg-elevated)"></div>
 <div class="flex-1 space-y-2">
 <div class="h-4 rounded w-1/3" style="background:var(--bg-elevated)"></div>
 <div class="h-3 rounded w-1/2" style="background:var(--bg-elevated)"></div>
 <div class="h-3 rounded w-1/4" style="background:var(--bg-elevated)"></div>
 </div>
 <div class="h-6 rounded-full w-12" style="background:var(--bg-elevated)"></div>
 </div>
 </div>
 </template>
 </div>

 <div x-show="!loading && !error" style="display:none">
 <div class="flex items-center justify-between mb-6">
 <p class="text-sm" style="color:var(--text-secondary)" x-text="providers.length + ' provider' + (providers.length !== 1 ? 's' : '')"></p>
 <button @click="openAddModal()" class="inline-flex items-center gap-2 px-4 py-2.5 text-white rounded-xl text-sm font-medium transition-colors shadow-sm" style="background:var(--accent)">
 <i class="fas fa-plus"></i>
 <span>Add Provider</span>
 </button>
 </div>

 <template x-if="providers.length === 0">
 <div class="flex flex-col items-center justify-center py-20" style="color:var(--text-muted)">
 <div class="w-20 h-20 rounded-2xl flex items-center justify-center mb-5" style="background:var(--bg-elevated)">
 <i class="fas fa-cloud text-4xl" style="color:var(--text-muted)"></i>
 </div>
 <p class="text-lg font-medium" style="color:var(--text-secondary)">No providers configured yet</p>
 <p class="text-sm mt-1.5 mb-6">Add your first AI provider to get started</p>
 <button @click="openAddModal()" class="inline-flex items-center gap-2 px-5 py-2.5 text-white rounded-xl text-sm font-medium transition-colors shadow-sm" style="background:var(--accent)">
 <i class="fas fa-plus"></i>
 <span>Add Provider</span>
 </button>
 </div>
 </template>

 <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
 <template x-for="(p, idx) in providers" :key="p._id">
 <div @click="navigate(p._id)" class="rounded-xl p-5 transition-all cursor-pointer relative" style="background:var(--bg-surface);border:1px solid var(--border-color)" :style="'animation-delay:'+(idx*50)+'ms'">
 <div class="flex items-start gap-4">
 <div :class="'w-12 h-12 rounded-xl flex items-center justify-center text-white font-bold text-lg flex-shrink-0 ' + letterColor(p.name)">
 <span x-text="(p.name || '?')[0].toUpperCase()"></span>
 </div>
 <div class="flex-1 min-w-0">
 <div class="flex items-center gap-2 flex-wrap">
 <h3 class="font-semibold truncate" style="color:var(--text-primary)" x-text="p.displayName || p.name"></h3>
 <span class="text-xs font-mono" style="color:var(--text-muted)" x-text="p.name ? '(' + p.name + ')' : ''"></span>
 <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold" style="background:rgba(99,102,241,0.2);color:#818cf8" x-text="'P' + (p.priority ?? 0)"></span>
 </div>
 <p x-show="p.baseUrl" class="text-xs font-mono truncate mt-0.5" style="color:var(--text-muted)" x-text="p.baseUrl"></p>
 <div class="flex items-center gap-2 mt-2 flex-wrap">
 <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs" style="color:var(--text-secondary);background:var(--bg-elevated)" x-text="(p.modelsCount || p.models?.length || 0) + ' models'"></span>
 <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs" style="color:var(--text-secondary);background:var(--bg-elevated)" x-text="(p.keysCount || p.apiKeys?.length || 0) + ' keys'"></span>
 <span x-show="p.rpm !== undefined || p.tpm !== undefined" class="text-xs" style="color:var(--text-muted)">
 <span x-text="'RPM: ' + (p.rpm ?? '-')"></span>
 <span x-show="p.rpm !== undefined || p.tpm !== undefined"> | </span>
 <span x-text="'TPM: ' + (p.tpm ?? '-')"></span>
 </span>
 </div>
 </div>
 <div class="flex flex-col items-center gap-2 flex-shrink-0" @click.stop>
 <button @click="toggleProvider(p._id, p.isEnabled)" type="button" :class="p.isEnabled ? 'bg-indigo-600' : ''" class="relative inline-flex h-5 w-9 items-center rounded-full transition-colors flex-shrink-0">
 <span :class="p.isEnabled ? 'translate-x-[18px]' : 'translate-x-[2px]'" class="inline-block h-3.5 w-3.5 transform rounded-full transition-transform shadow-sm" style="background:var(--toggle-knob)"></span>
 </button>
 <button @click="deleteProvider(p._id, p.displayName || p.name)" type="button" class="p-1.5 rounded-lg transition-colors" style="color:var(--text-muted)" title="Delete provider">
 <i class="fas fa-trash-alt text-xs"></i>
 </button>
 </div>
 </div>
 </div>
 </template>
 </div>
 </div>
 </div>

 <footer class="px-4 md:px-8 py-4 flex items-center justify-between text-xs" style="border-color:var(--border-color);background:var(--bg-surface);color:var(--text-muted)">
 <span>&copy; 2026 Gapat Bot</span>
 <span x-data="healthFooter()" x-init="init()">
 <template x-if="health === null">
 <span><i class="fas fa-spinner fa-spin mr-1"></i>Checking API...</span>
 </template>
 <template x-if="health === true">
 <span><i class="fas fa-circle text-emerald-400 text-[8px] mr-1"></i>API Online</span>
 </template>
 <template x-if="health === false">
 <span><i class="fas fa-circle text-red-400 text-[8px] mr-1"></i>API Offline</span>
 </template>
 </span>
 </footer>
</div>

<div x-show="showAddModal" class="fixed inset-0 z-[60] flex items-center justify-center p-4 modal-overlay" style="display:none">
 <div @click="showAddModal = false" class="absolute inset-0"></div>
 <div @click.stop class="rounded-2xl shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto modal-content relative z-10" style="background:var(--bg-surface);border:1px solid var(--border-color)">
 <div class="flex items-center justify-between px-6 pt-6 pb-4" style="border-bottom:1px solid var(--border-color)">
 <h2 class="text-lg font-bold" style="color:var(--text-primary)">Add Provider</h2>
 <button @click="showAddModal = false" class="w-8 h-8 rounded-lg flex items-center justify-center" style="color:var(--text-muted);background:var(--bg-elevated)">
 <i class="fas fa-times"></i>
 </button>
 </div>
 <div class="p-6 space-y-4">
 <div>
 <label class="block text-xs font-medium uppercase tracking-wider mb-1.5" style="color:var(--text-secondary)">Provider Type <span style="color:#f87171">*</span></label>
 <select x-model="form.name" @change="onProviderTypeChange()" class="w-full px-3.5 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:border-transparent" style="background:var(--bg-elevated);border-color:var(--border-color);color:var(--text-primary)">
 <option value="" disabled>Select provider...</option>
 <option value="openai">OpenAI</option>
 <option value="anthropic">Anthropic</option>
 <option value="google">Google (Gemini)</option>
 <option value="openrouter">OpenRouter</option>
 <option value="custom">Custom (Ollama / OpenAI-compatible)</option>
 </select>
 </div>
 <div>
 <label class="block text-xs font-medium uppercase tracking-wider mb-1.5" style="color:var(--text-secondary)">Display Name <span style="color:#f87171">*</span></label>
 <input x-model="form.displayName" type="text" placeholder="My Provider" class="w-full px-3.5 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:border-transparent" style="background:var(--bg-elevated);border-color:var(--border-color);color:var(--text-primary)">
 </div>
 <div x-show="form.name === 'custom'" x-transition class="space-y-4">
 <div>
 <label class="block text-xs font-medium uppercase tracking-wider mb-1.5" style="color:var(--text-secondary)">Base URL <span style="color:#f87171">*</span></label>
 <input x-model="form.baseUrl" type="text" placeholder="http://localhost:11434/v1" class="w-full px-3.5 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:border-transparent" style="background:var(--bg-elevated);border-color:var(--border-color);color:var(--text-primary)">
 <p class="text-xs mt-1.5" style="color:var(--text-muted)">OpenAI-compatible API endpoint</p>
 </div>
 </div>
 <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
 <div>
 <label class="block text-xs font-medium uppercase tracking-wider mb-1.5" style="color:var(--text-secondary)">Priority</label>
 <input x-model="form.priority" type="number" class="w-full px-3.5 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:border-transparent" style="background:var(--bg-elevated);border-color:var(--border-color);color:var(--text-primary)">
 </div>
 <div>
 <label class="block text-xs font-medium uppercase tracking-wider mb-1.5" style="color:var(--text-secondary)">RPM</label>
 <input x-model="form.rpm" type="number" placeholder="Optional" class="w-full px-3.5 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:border-transparent" style="background:var(--bg-elevated);border-color:var(--border-color);color:var(--text-primary)">
 </div>
 <div>
 <label class="block text-xs font-medium uppercase tracking-wider mb-1.5" style="color:var(--text-secondary)">TPM</label>
 <input x-model="form.tpm" type="number" placeholder="Optional" class="w-full px-3.5 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:border-transparent" style="background:var(--bg-elevated);border-color:var(--border-color);color:var(--text-primary)">
 </div>
 </div>
 <div class="flex items-center justify-between py-2">
 <span class="text-sm font-medium" style="color:var(--text-secondary)">Enabled</span>
 <button @click="form.isEnabled = !form.isEnabled" type="button" :class="form.isEnabled ? 'bg-indigo-600' : ''" class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors flex-shrink-0">
 <span :class="form.isEnabled ? 'translate-x-6' : 'translate-x-1'" class="inline-block h-4 w-4 transform rounded-full transition-transform shadow-sm" style="background:var(--toggle-knob)"></span>
 </button>
 </div>
 </div>
 <div class="flex items-center justify-end gap-3 px-6 pb-6 pt-4" style="border-top:1px solid var(--border-color)">
 <button @click="showAddModal = false" class="px-4 py-2.5 text-sm font-medium transition-colors" style="color:var(--text-secondary)">Cancel</button>
 <button @click="addProvider()" :disabled="saving" class="inline-flex items-center gap-2 px-5 py-2.5 disabled:opacity-50 disabled:cursor-not-allowed text-white rounded-xl text-sm font-medium transition-colors shadow-sm" style="background:var(--accent)">
 <i x-show="saving" class="fas fa-spinner fa-spin" style="display:none"></i>
 <span x-text="saving ? 'Saving...' : 'Create Provider'"></span>
 </button>
 </div>
 </div>
</div>

<script>
function providersData() {
 return {
 loading: true,
 error: '',
 path: window.location.pathname,
 providers: [],
 showAddModal: false,
 saving: false,
 form: { name: '', displayName: '', baseUrl: '', priority: 0, rpm: '', tpm: '', isEnabled: true },
 providerDefaults: {
 openai: { displayName: 'OpenAI', baseUrl: 'https://api.openai.com/v1' },
 anthropic: { displayName: 'Anthropic', baseUrl: 'https://api.anthropic.com' },
 google: { displayName: 'Google (Gemini)', baseUrl: 'https://generativelanguage.googleapis.com/v1beta' },
 openrouter: { displayName: 'OpenRouter', baseUrl: 'https://openrouter.ai/api/v1' },
 custom: { displayName: 'Custom (Ollama)', baseUrl: '' },
 },
 onProviderTypeChange() {
 const d = this.providerDefaults[this.form.name];
 if (d) {
 if (!this.form.displayName || Object.values(this.providerDefaults).some(v => v.displayName === this.form.displayName)) {
 this.form.displayName = d.displayName;
 }
 this.form.baseUrl = d.baseUrl;
 }
 },
 colors: ['bg-indigo-500', 'bg-emerald-500', 'bg-amber-500', 'bg-rose-500', 'bg-cyan-500', 'bg-violet-500', 'bg-orange-500', 'bg-teal-500', 'bg-pink-500', 'bg-blue-500'],
 letterColor(name) {
 if (!name) return this.colors[0];
 return this.colors[(name.charCodeAt(0) || 65) % this.colors.length];
 },
 async init() {
 try {
 const data = await API.get('/api/v1/providers');
 this.providers = Array.isArray(data) ? data : (data?.data || data?.providers || []);
 } catch (e) {
 this.error = '❌ ' + (e?.message || 'Failed to load providers');
 showToast('Failed to load providers', 'error');
 } finally {
 this.loading = false;
 }
 },
 retry() {
 this.error = '';
 this.loading = true;
 this.init();
 },
 navigate(id) {
 window.location.href = '/settings/providers/' + id;
 },
 openAddModal() {
 this.form = { name: '', displayName: '', baseUrl: '', priority: 0, rpm: '', tpm: '', isEnabled: true };
 this.showAddModal = true;
 },
 async addProvider() {
 if (!this.form.name.trim() || !this.form.displayName.trim()) {
 showToast('Provider Type and Display Name are required', 'warning');
 return;
 }
 if (this.form.name === 'custom' && !this.form.baseUrl.trim()) {
 showToast('Base URL is required for Custom provider', 'warning');
 return;
 }
 this.saving = true;
 try {
 const body = {
 name: this.form.name.trim(),
 displayName: this.form.displayName.trim(),
 baseUrl: this.form.baseUrl.trim() || undefined,
 priority: parseInt(this.form.priority) || 0
 };
 if (this.form.rpm !== '' && this.form.rpm !== null) body.rpm = parseInt(this.form.rpm);
 if (this.form.tpm !== '' && this.form.tpm !== null) body.tpm = parseInt(this.form.tpm);
 body.isEnabled = this.form.isEnabled;
 await API.post('/api/v1/providers', body);
 showToast('Provider created successfully', 'success');
 this.showAddModal = false;
 const data = await API.get('/api/v1/providers');
 this.providers = Array.isArray(data) ? data : (data?.data || data?.providers || []);
 } catch (e) {
 showToast(e?.message || 'Failed to create provider', 'error');
 } finally {
 this.saving = false;
 }
 },
 async toggleProvider(id, current) {
 try {
 await API.patch('/api/v1/providers/' + id, { isEnabled: !current });
 showToast('Provider ' + (!current ? 'enabled' : 'disabled'), !current ? 'success' : 'warning');
 const data = await API.get('/api/v1/providers');
 this.providers = Array.isArray(data) ? data : (data?.data || data?.providers || []);
 } catch (e) {
 showToast(e?.message || 'Failed to update provider', 'error');
 }
 },
 async deleteProvider(id, name) {
  if (!(await confirmDialog({ title: 'Delete Provider', message: 'Are you sure you want to delete "' + name + '"? This action cannot be undone.', confirmText: 'Delete', danger: true }))) return;
 try {
 await API.del('/api/v1/providers/' + id);
 showToast('Provider deleted', 'success');
 const data = await API.get('/api/v1/providers');
 this.providers = Array.isArray(data) ? data : (data?.data || data?.providers || []);
 } catch (e) {
 showToast(e?.message || 'Failed to delete provider', 'error');
 }
 }
 };
}
</script>
</body>
</html>
