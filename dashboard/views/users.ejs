<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gapat Bot — Users</title>
<link rel="icon" href="/img/favicon.ico" type="image/x-icon">
<link rel="stylesheet" href="/css/style.css">
<script src="https://cdn.tailwindcss.com"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');</style>
</head>
<body class="min-h-screen" style="background:var(--bg-base);color:var(--text-primary)" x-data="usersData()" x-init="init(); $store.user.init()" >
 <script src="/js/app.js"></script>

 <%- include('partials/sidebar') %>

 <div class="main-content min-h-screen flex flex-col" :class="{ 'full': !$store.app.sidebarOpen }">
 <header class="sticky top-0 z-30 px-4 md:px-8 py-4 flex items-center gap-4" style="background:var(--header-bg);border-bottom:1px solid var(--border-color);backdrop-filter:blur(12px)">
 <button @click="$store.app.toggleSidebar()" class="p-2 -ml-2 rounded-lg" style="background:var(--bg-elevated);color:var(--text-muted)">
 <i class="fas fa-bars text-xl"></i>
 </button>
 <a :href="'/servers/' + guildId" class="p-1.5 -ml-1 rounded-lg" style="background:var(--bg-elevated);color:var(--text-muted)">
 <i class="fas fa-arrow-left"></i>
 </a>
 <div class="flex items-center gap-2 min-w-0">
 <h1 class="text-xl font-bold truncate" x-text="guild?.name ? guild.name + ' — Users' : 'Users'" style="color:var(--text-primary)"></h1>
 <span x-show="guild" class="hidden md:inline text-sm font-mono" x-text="guild.id" style="color:var(--text-muted)"></span>
 </div>
 <div class="ml-auto flex items-center gap-3 text-sm">
 <template x-if="$store.user.avatar">
 <img :src="$store.user.avatar" class="w-7 h-7 rounded-full" :alt="$store.user.username">
 </template>
 <span class="hidden sm:inline font-medium" x-text="$store.user.username" style="color:var(--text-secondary)"></span>
 <span class="hidden sm:inline" style="color:var(--text-muted)">·</span>
 <i class="fas fa-circle text-emerald-400 text-xs"></i>
 <span class="hidden sm:inline" style="color:var(--text-secondary)">Online</span>
 <span x-show="$store.user.role === 'owner'" class="px-2 py-0.5 rounded-full text-xs font-medium">Owner</span>
 <span x-show="$store.user.role === 'admin'" class="px-2 py-0.5 rounded-full text-xs font-medium">Admin</span>
 </div>
 </header>

 <div class="p-4 md:p-8 flex-1">
 <div x-show="loading" class="flex items-center justify-center py-20" style="display:none;color:var(--text-muted)">
 <i class="fas fa-spinner fa-spin text-2xl mr-3"></i>
 <span>Loading users...</span>
 </div>

 <div x-show="!loading && error" class="border border-[var(--border-rose)] px-5 py-3 rounded-xl mb-6" x-text="error" style="display:none"></div>

 <div x-show="!loading && !error && users.length === 0" class="flex flex-col items-center justify-center py-20" style="display:none;color:var(--text-muted)">
 <i class="fas fa-users text-5xl mb-4" style="color:var(--text-muted)"></i>
 <p class="text-lg font-medium" style="color:var(--text-secondary)">No user activity today</p>
 <p class="text-sm mt-1">Users will appear here once they interact with the bot.</p>
 </div>

 <div x-show="!loading && !error && users.length" class="hidden md:block overflow-hidden rounded-xl border" style="display:none;border-color:var(--border-color);background:var(--bg-surface)">
 <table class="w-full text-sm">
 <thead>
 <tr style="background:var(--bg-elevated);border-bottom:1px solid var(--border-color)">
 <th class="text-left px-4 py-3 font-semibold text-xs uppercase tracking-wider" style="color:var(--text-secondary)">User ID</th>
 <th class="text-left px-4 py-3 font-semibold text-xs uppercase tracking-wider w-1/3" style="color:var(--text-secondary)">Tokens Used / Daily Limit</th>
 <th class="text-left px-4 py-3 font-semibold text-xs uppercase tracking-wider w-1/3" style="color:var(--text-secondary)">Requests Used / Daily Limit</th>
 <th class="text-center px-4 py-3 font-semibold text-xs uppercase tracking-wider" style="color:var(--text-secondary)">Last Request</th>
 <th class="text-right px-4 py-3 font-semibold text-xs uppercase tracking-wider" style="color:var(--text-secondary)">Actions</th>
 </tr>
 </thead>
 <tbody>
 <template x-for="u in users" :key="u.userId">
 <tr style="background:var(--bg-surface)">
 <td class="px-4 py-3 font-medium font-mono text-xs" x-text="u.userId" style="color:var(--text-primary)"></td>
 <td class="px-4 py-3">
 <div class="flex items-center gap-3">
 <div class="flex-1">
 <div class="flex items-center justify-between mb-1">
 <span class="text-xs font-medium" x-text="fmt(u.tokensUsed) + ' / ' + fmt(u.dailyTokenLimit || guild?.dailyTokenLimit || 50000)" style="color:var(--text-secondary)"></span>
 <span class="text-xs" x-text="pct(u.tokensUsed, u.dailyTokenLimit || guild?.dailyTokenLimit || 50000) + '%'" style="color:var(--text-muted)"></span>
 </div>
 <div class="w-full h-2 rounded-full overflow-hidden" style="background:var(--bg-elevated)">
 <div class="h-full rounded-full transition-all" :style="'width:' + pct(u.tokensUsed, u.dailyTokenLimit || guild?.dailyTokenLimit || 50000) + '%'" :class="pct(u.tokensUsed, u.dailyTokenLimit || guild?.dailyTokenLimit || 50000) > 80 ? 'bg-red-500' : pct(u.tokensUsed, u.dailyTokenLimit || guild?.dailyTokenLimit || 50000) > 50 ? 'bg-amber-500' : 'bg-emerald-500'"></div>
 </div>
 </div>
 <button @click="editLimits(u, 'tokens')" class="p-1.5 rounded-lg" style="background:var(--bg-elevated);color:var(--text-muted)" title="Override token limit">
 <i class="fas fa-pen text-[10px]"></i>
 </button>
 </div>
 </td>
 <td class="px-4 py-3">
 <div class="flex items-center gap-3">
 <div class="flex-1">
 <div class="flex items-center justify-between mb-1">
 <span class="text-xs font-medium" x-text="fmt(u.requestsUsed) + ' / ' + fmt(u.dailyRequestLimit || guild?.dailyRequestLimit || 100)" style="color:var(--text-secondary)"></span>
 <span class="text-xs" x-text="pct(u.requestsUsed, u.dailyRequestLimit || guild?.dailyRequestLimit || 100) + '%'" style="color:var(--text-muted)"></span>
 </div>
 <div class="w-full h-2 rounded-full overflow-hidden" style="background:var(--bg-elevated)">
 <div class="h-full rounded-full transition-all" :style="'width:' + pct(u.requestsUsed, u.dailyRequestLimit || guild?.dailyRequestLimit || 100) + '%'" :class="pct(u.requestsUsed, u.dailyRequestLimit || guild?.dailyRequestLimit || 100) > 80 ? 'bg-red-500' : pct(u.requestsUsed, u.dailyRequestLimit || guild?.dailyRequestLimit || 100) > 50 ? 'bg-amber-500' : 'bg-blue-500'"></div>
 </div>
 </div>
 <button @click="editLimits(u, 'requests')" class="p-1.5 rounded-lg" style="background:var(--bg-elevated);color:var(--text-muted)" title="Override request limit">
 <i class="fas fa-pen text-[10px]"></i>
 </button>
 </div>
 </td>
 <td class="px-4 py-3 text-center text-xs" x-text="u.lastRequestAt ? timeAgo(u.lastRequestAt) : '—'" style="color:var(--text-muted)"></td>
 <td class="px-4 py-3 text-right">
 <button @click="resetAll(u)" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-red-600 transition-colors" title="Reset all user data (limits + conversations)">
 <i class="fas fa-trash"></i><span class="hidden lg:inline">Reset All</span>
 </button>
 </td>
 </tr>
 </template>
 </tbody>
 </table>
 </div>

 <div x-show="!loading && !error && users.length" class="md:hidden space-y-3" style="display:none">
 <template x-for="u in users" :key="u.userId">
 <div class="rounded-xl border p-4 hover:shadow-sm transition-shadow" style="background:var(--bg-surface);border-color:var(--border-color)">
 <p class="font-mono text-xs font-semibold mb-3" x-text="u.userId" style="color:var(--text-primary)"></p>
 <div class="space-y-3 mb-3">
 <div>
 <div class="flex items-center justify-between text-xs mb-1">
 <span style="color:var(--text-muted)">Tokens</span>
 <span class="font-medium" x-text="fmt(u.tokensUsed) + ' / ' + fmt(u.dailyTokenLimit || guild?.dailyTokenLimit || 50000)" style="color:var(--text-secondary)"></span>
 </div>
 <div class="w-full h-2 rounded-full overflow-hidden" style="background:var(--bg-elevated)">
 <div class="h-full rounded-full" :style="'width:' + pct(u.tokensUsed, u.dailyTokenLimit || guild?.dailyTokenLimit || 50000) + '%'" :class="pct(u.tokensUsed, u.dailyTokenLimit || guild?.dailyTokenLimit || 50000) > 80 ? 'bg-red-500' : pct(u.tokensUsed, u.dailyTokenLimit || guild?.dailyTokenLimit || 50000) > 50 ? 'bg-amber-500' : 'bg-emerald-500'"></div>
 </div>
 </div>
 <div>
 <div class="flex items-center justify-between text-xs mb-1">
 <span style="color:var(--text-muted)">Requests</span>
 <span class="font-medium" x-text="fmt(u.requestsUsed) + ' / ' + fmt(u.dailyRequestLimit || guild?.dailyRequestLimit || 100)" style="color:var(--text-secondary)"></span>
 </div>
 <div class="w-full h-2 rounded-full overflow-hidden" style="background:var(--bg-elevated)">
 <div class="h-full rounded-full" :style="'width:' + pct(u.requestsUsed, u.dailyRequestLimit || guild?.dailyRequestLimit || 100) + '%'" :class="pct(u.requestsUsed, u.dailyRequestLimit || guild?.dailyRequestLimit || 100) > 80 ? 'bg-red-500' : pct(u.requestsUsed, u.dailyRequestLimit || guild?.dailyRequestLimit || 100) > 50 ? 'bg-amber-500' : 'bg-blue-500'"></div>
 </div>
 </div>
 </div>
 <div class="flex items-center justify-between text-xs mb-3" style="color:var(--text-muted)">
 <span x-show="u.lastRequestAt"><i class="fas fa-clock mr-1"></i><span x-text="timeAgo(u.lastRequestAt)"></span></span>
 </div>
 <button @click="resetAll(u)" class="w-full inline-flex items-center justify-center gap-1.5 px-3 py-2 text-red-600 rounded-xl text-xs font-medium transition-colors">
 <i class="fas fa-trash"></i><span>Reset All</span>
 </button>
 </div>
 </template>
 </div>
 </div>

 <footer class="px-4 md:px-8 py-4 flex items-center justify-between text-xs" style="border-top:1px solid var(--border-color);background:var(--bg-surface);color:var(--text-muted)">
 <span>&copy; 2026 Gapat Bot</span>
 <span x-data="healthFooter()" x-init="init()">
 <template x-if="health === null">
 <span><i class="fas fa-spinner fa-spin mr-1"></i>Checking API...</span>
 </template>
 <template x-if="health === true">
 <span><i class="fas fa-circle text-emerald-400 text-[8px] mr-1"></i>API Online</span>
 </template>
 <template x-if="health === false">
 <span><i class="fas fa-circle text-red-400 text-[8px] mr-1"></i>API Offline</span>
 </template>
 </span>
 </footer>
 </div>

 <!-- Inline Override Limits Modal -->
 <div x-show="showLimitsModal" class="fixed inset-0 z-[60] flex items-center justify-center p-4" style="display:none">
 <div class="modal-overlay fixed inset-0" @click="showLimitsModal = false"></div>
 <div @click.stop class="modal-content rounded-2xl shadow-2xl border w-full max-w-sm p-6 relative z-10" style="background:var(--bg-surface);border-color:var(--border-color)">
 <div class="flex items-center justify-between mb-5">
 <h2 class="text-lg font-bold" style="color:var(--text-primary)">Override Limits</h2>
 <button @click="showLimitsModal = false" class="p-1.5 rounded-lg" style="background:var(--bg-elevated);color:var(--text-muted)">
 <i class="fas fa-times"></i>
 </button>
 </div>
 <p class="text-xs font-mono mb-4" x-text="'User: ' + limitingUser?.userId" style="color:var(--text-muted)"></p>
 <div class="space-y-4">
 <div>
 <label class="block text-sm font-medium mb-1" style="color:var(--text-secondary)">Tokens Used (override)</label>
 <input x-model.number="limitsForm.tokensUsed" type="number" min="0" class="w-full px-3 py-2.5 border rounded-xl text-sm transition-all" style="background:var(--bg-surface);border-color:var(--border-color);color:var(--text-primary)" focus:outline-none focus:ring-2 focus:ring-[var(--accent)]>
 </div>
 <div>
 <label class="block text-sm font-medium mb-1" style="color:var(--text-secondary)">Requests Used (override)</label>
 <input x-model.number="limitsForm.requestsUsed" type="number" min="0" class="w-full px-3 py-2.5 border rounded-xl text-sm transition-all" style="background:var(--bg-surface);border-color:var(--border-color);color:var(--text-primary)" focus:outline-none focus:ring-2 focus:ring-[var(--accent)]>
 </div>
 </div>
 <div class="flex items-center gap-3 mt-6 pt-4" style="border-top:1px solid var(--border-color)">
 <button @click="saveLimits()" :disabled="saving" class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 disabled:opacity-60 text-white font-medium rounded-xl text-sm transition-colors">
 <i x-show="saving" class="fas fa-spinner fa-spin"></i>
 <span x-text="saving ? 'Saving...' : 'Save Override'"></span>
 </button>
 <button @click="showLimitsModal = false" class="px-4 py-2.5 border rounded-xl text-sm transition-colors" style="background:var(--bg-surface);border-color:var(--border-color);color:var(--text-secondary)">Cancel</button>
 </div>
 </div>
 </div>

 <script>
 function usersData() {
 return {
 loading: true,
 error: '',
 path: window.location.pathname,
 guildId: '',
 guild: null,
 users: [],
 showLimitsModal: false,
 limitingUser: null,
 saving: false,
 limitsForm: { tokensUsed: 0, requestsUsed: 0 },
 async init() {
 const parts = window.location.pathname.split('/').filter(Boolean);
 this.guildId = parts[1];
 if (!this.guildId) { this.error = 'No server ID specified.'; this.loading = false; return; }
 try {
 const [guild, users] = await Promise.all([
 API.get('/api/v1/guilds/' + this.guildId),
 API.get('/api/v1/guilds/' + this.guildId + '/users')
 ]);
 if (!guild || guild.error) { this.error = (guild && guild.error) || 'Server not found.'; this.loading = false; return; }
 this.guild = guild;
 this.users = Array.isArray(users) ? users : (users?.data || users?.users || []);
 } catch (e) {
 this.error = '❌ ' + (e?.message || 'Failed to load user');
 showToast('Failed to load user', 'error');
 } finally {
 this.loading = false;
 }
 },
 editLimits(u, type) {
 this.limitingUser = u;
 this.limitsForm = { tokensUsed: u.tokensUsed || 0, requestsUsed: u.requestsUsed || 0 };
 this.showLimitsModal = true;
 },
 async saveLimits() {
 this.saving = true;
 try {
 await API.patch('/api/v1/guilds/' + this.guildId + '/users/' + this.limitingUser.userId + '/limits', {
 tokensUsed: this.limitsForm.tokensUsed,
 requestsUsed: this.limitsForm.requestsUsed
 });
 showToast('User limits updated', 'success');
 this.showLimitsModal = false;
 this.limitingUser.tokensUsed = this.limitsForm.tokensUsed;
 this.limitingUser.requestsUsed = this.limitsForm.requestsUsed;
 } catch (e) {
 showToast('Failed to update limits', 'error');
 } finally {
 this.saving = false;
 }
 },
 async resetAll(u) {
  if (!(await confirmDialog({ title: 'Reset User', message: 'Reset ALL data for this user? Daily limits + conversation history will be permanently deleted.', confirmText: 'Reset', danger: true }))) return;
 try {
 const result = await API.post('/api/v1/guilds/' + this.guildId + '/users/' + u.userId + '/reset-all', {});
 showToast('User reset: ' + result.deleted.conversations + ' conversations deleted, ' + result.deleted.userLimits + ' limits deleted', 'success');
 u.tokensUsed = 0;
 u.requestsUsed = 0;
 if (result.deleted.conversations > 0) {
 this.users = this.users.filter(x => x.userId !== u.userId);
 }
 } catch (e) {
 showToast('Failed to reset user: ' + (e?.message || 'Unknown'), 'error');
 }
 }
 };
 }
 </script>
</body>
</html>