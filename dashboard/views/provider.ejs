<script>
function providerDetail() {
 return {
 loading: true,
 error: '',
 path: window.location.pathname,
 providerId: window.location.pathname.split('/').pop(),
 provider: null,
 providerName: '',
 tab: 'info',
 keys: [],
 models: [],
 saving: false,
 savingKey: false,
 savingModel: false,
 infoForm: { displayName: '', baseUrl: '', priority: 0, rpm: '', tpm: '', isEnabled: true },
 showAddKeyModal: false,
 keyForm: { label: '', apiKey: '', rpm: '', tpm: '', maxDailyRequests: '', maxDailyTokens: '' },
 showEditKeyModal: false,
 editKeyForm: { _id: '', label: '', isActive: true, rpm: '', tpm: '', maxDailyRequests: '', maxDailyTokens: '' },
 showAddModelModal: false,
 modelForm: { id: '', displayName: '', provider: '', maxContextTokens: 128000, maxOutputTokens: 4096, supportsVision: false, supportsFunctions: false, supportsJsonMode: false, inputCostPer1k: 0, outputCostPer1k: 0, isEnabled: true },
 showEditModelModal: false,
 editModelForm: { _id: '', id: '', displayName: '', provider: '', maxContextTokens: 128000, maxOutputTokens: 4096, supportsVision: false, supportsFunctions: false, supportsJsonMode: false, inputCostPer1k: 0, outputCostPer1k: 0, isEnabled: true },
 async init() {
 try {
 this.provider = await API.get('/api/v1/providers/' + this.providerId);
 this.providerName = this.provider.displayName || this.provider.name || '';
 this.populateInfoForm();
 await Promise.all([this.loadKeys(), this.loadModels()]);
 } catch (e) {
 this.error = '❌ ' + (e?.message || 'Failed to load provider');
 showToast('Failed to load provider', 'error');
 } finally {
 this.loading = false;
 }
 },
 retry() {
 this.error = '';
 this.loading = true;
 this.init();
 },
 populateInfoForm() {
 this.infoForm.displayName = this.provider.displayName || '';
 this.infoForm.baseUrl = this.provider.baseUrl || '';
 this.infoForm.priority = this.provider.priority ?? 0;
 this.infoForm.rpm = this.provider.rateLimits?.requestsPerMinute ?? '';
 this.infoForm.tpm = this.provider.rateLimits?.tokensPerMinute ?? '';
 this.infoForm.isEnabled = this.provider.isEnabled ?? true;
 },
 async loadProvider() {
 try {
 this.provider = await API.get('/api/v1/providers/' + this.providerId);
 this.providerName = this.provider.displayName || this.provider.name || '';
 this.populateInfoForm();
 } catch (e) {
 showToast('Failed to reload provider', 'error');
 }
 },
 async loadKeys() {
 try {
 const data = await API.get('/api/v1/providers/' + this.providerId + '/keys');
 this.keys = Array.isArray(data) ? data : (data?.data || data?.keys || []);
 } catch (e) {
 showToast('Failed to load keys', 'error');
 this.keys = [];
 }
 },
 async loadModels() {
 try {
 const data = await API.get('/api/v1/providers/' + this.providerId + '/models');
 this.models = Array.isArray(data) ? data : (data?.data || data?.models || []);
 } catch (e) {
 showToast('Failed to load models', 'error');
 this.models = [];
 }
 },
 async saveProvider() {
 this.saving = true;
 try {
 const body = {
 displayName: this.infoForm.displayName.trim(),
 baseUrl: this.infoForm.baseUrl.trim() || undefined,
 priority: parseInt(this.infoForm.priority) || 0,
 isEnabled: this.infoForm.isEnabled
 };
 const rpm = parseInt(this.infoForm.rpm);
 const tpm = parseInt(this.infoForm.tpm);
 if (!isNaN(rpm) || !isNaN(tpm)) {
 body.rateLimits = {};
 if (!isNaN(rpm)) body.rateLimits.requestsPerMinute = rpm;
 if (!isNaN(tpm)) body.rateLimits.tokensPerMinute = tpm;
 }
 await API.patch('/api/v1/providers/' + this.providerId, body);
 showToast('Provider updated', 'success');
 await this.loadProvider();
 } catch (e) {
 showToast(e?.message || 'Failed to update provider', 'error');
 } finally {
 this.saving = false;
 }
 },
 openAddKeyModal() {
 this.keyForm = { label: '', apiKey: '', rpm: '', tpm: '', maxDailyRequests: '', maxDailyTokens: '' };
 this.showAddKeyModal = true;
 },
 async addKey() {
 if (!this.keyForm.label.trim() || !this.keyForm.apiKey.trim()) {
 showToast('Label and API Key are required', 'warning');
 return;
 }
 this.savingKey = true;
 try {
 const body = { label: this.keyForm.label.trim(), apiKey: this.keyForm.apiKey.trim() };
 const pl = {};
 const rpm = parseInt(this.keyForm.rpm);
 const tpm = parseInt(this.keyForm.tpm);
 const rpd = parseInt(this.keyForm.maxDailyRequests);
 const tpd = parseInt(this.keyForm.maxDailyTokens);
 if (!isNaN(rpm)) pl.requestsPerMinute = rpm;
 if (!isNaN(tpm)) pl.tokensPerMinute = tpm;
 if (!isNaN(rpd)) pl.requestsPerDay = rpd;
 if (!isNaN(tpd)) pl.tokensPerDay = tpd;
 if (Object.keys(pl).length) body.providerLimits = pl;
 await API.post('/api/v1/providers/' + this.providerId + '/keys', body);
 showToast('API key added', 'success');
 this.showAddKeyModal = false;
 await this.loadKeys();
 } catch (e) {
 showToast(e?.message || 'Failed to add key', 'error');
 } finally {
 this.savingKey = false;
 }
 },
 openEditKeyModal(k) {
 const pl = k.providerLimits || {};
 this.editKeyForm = {
 _id: k._id,
 label: k.label || '',
 isActive: k.isActive ?? true,
 rpm: pl.requestsPerMinute ?? '',
 tpm: pl.tokensPerMinute ?? '',
 maxDailyRequests: pl.requestsPerDay ?? '',
 maxDailyTokens: pl.tokensPerDay ?? ''
 };
 this.showEditKeyModal = true;
 },
 async editKey() {
 this.savingKey = true;
 try {
 const body = { label: this.editKeyForm.label.trim(), isActive: this.editKeyForm.isActive };
 const pl = {};
 const rpm = parseInt(this.editKeyForm.rpm);
 const tpm = parseInt(this.editKeyForm.tpm);
 const rpd = parseInt(this.editKeyForm.maxDailyRequests);
 const tpd = parseInt(this.editKeyForm.maxDailyTokens);
 if (!isNaN(rpm)) pl.requestsPerMinute = rpm;
 if (!isNaN(tpm)) pl.tokensPerMinute = tpm;
 if (!isNaN(rpd)) pl.requestsPerDay = rpd;
 if (!isNaN(tpd)) pl.tokensPerDay = tpd;
 if (Object.keys(pl).length) body.providerLimits = pl;
 await API.patch('/api/v1/providers/' + this.providerId + '/keys/' + this.editKeyForm._id, body);
 showToast('API key updated', 'success');
 this.showEditKeyModal = false;
 await this.loadKeys();
 } catch (e) {
 showToast(e?.message || 'Failed to update key', 'error');
 } finally {
 this.savingKey = false;
 }
 },
 async toggleKey(id, current) {
 try {
 await API.patch('/api/v1/providers/' + this.providerId + '/keys/' + id, { isActive: !current });
 showToast('Key ' + (!current ? 'enabled' : 'disabled'), !current ? 'success' : 'warning');
 await this.loadKeys();
 } catch (e) {
 showToast(e?.message || 'Failed to update key', 'error');
 }
 },
 async deleteKey(id, label) {
 if (!(await confirmDialog({ title: 'Delete API Key', message: 'Delete API key "' + label + '"? This cannot be undone.', confirmText: 'Delete', danger: true }))) return;
 try {
 await API.del('/api/v1/providers/' + this.providerId + '/keys/' + id);
 showToast('API key deleted', 'success');
 await this.loadKeys();
 } catch (e) {
 showToast(e?.message || 'Failed to delete key', 'error');
 }
 },
 openAddModelModal() {
 this.modelForm = { id: '', displayName: '', provider: this.provider?.name || '', maxContextTokens: 128000, maxOutputTokens: 4096, supportsVision: false, supportsFunctions: false, supportsJsonMode: false, inputCostPer1k: 0, outputCostPer1k: 0, isEnabled: true };
 this.showAddModelModal = true;
 },
 async addModel() {
 if (!this.modelForm.id.trim() || !this.modelForm.displayName.trim()) {
 showToast('Model ID and Display Name are required', 'warning');
 return;
 }
 this.savingModel = true;
 try {
 const body = {
 id: this.modelForm.id.trim(),
 displayName: this.modelForm.displayName.trim(),
 provider: this.provider?.name || '',
 maxContextTokens: parseInt(this.modelForm.maxContextTokens) || 128000,
 maxOutputTokens: parseInt(this.modelForm.maxOutputTokens) || 4096,
 supportsVision: !!this.modelForm.supportsVision,
 supportsFunctions: !!this.modelForm.supportsFunctions,
 supportsJsonMode: !!this.modelForm.supportsJsonMode,
 inputCostPer1k: parseFloat(this.modelForm.inputCostPer1k) || 0,
 outputCostPer1k: parseFloat(this.modelForm.outputCostPer1k) || 0,
 isEnabled: this.modelForm.isEnabled
 };
 await API.post('/api/v1/providers/' + this.providerId + '/models', body);
 showToast('Model added', 'success');
 this.showAddModelModal = false;
 await this.loadModels();
 } catch (e) {
 showToast(e?.message || 'Failed to add model', 'error');
 } finally {
 this.savingModel = false;
 }
 },
 openEditModelModal(m) {
 this.editModelForm = {
 _id: m._id,
 id: m.id || '',
 displayName: m.displayName || '',
 provider: this.provider?.name || '',
 maxContextTokens: m.maxContextTokens ?? 128000,
 maxOutputTokens: m.maxOutputTokens ?? 4096,
 supportsVision: !!m.supportsVision,
 supportsFunctions: !!m.supportsFunctions,
 supportsJsonMode: !!m.supportsJsonMode,
 inputCostPer1k: m.inputCostPer1k ?? 0,
 outputCostPer1k: m.outputCostPer1k ?? 0,
 isEnabled: m.isEnabled ?? true
 };
 this.showEditModelModal = true;
 },
 async editModel() {
 this.savingModel = true;
 try {
 const body = {
 displayName: this.editModelForm.displayName.trim(),
 maxContextTokens: parseInt(this.editModelForm.maxContextTokens) || 128000,
 maxOutputTokens: parseInt(this.editModelForm.maxOutputTokens) || 4096,
 supportsVision: !!this.editModelForm.supportsVision,
 supportsFunctions: !!this.editModelForm.supportsFunctions,
 supportsJsonMode: !!this.editModelForm.supportsJsonMode,
 inputCostPer1k: parseFloat(this.editModelForm.inputCostPer1k) || 0,
 outputCostPer1k: parseFloat(this.editModelForm.outputCostPer1k) || 0,
 isEnabled: this.editModelForm.isEnabled
 };
 await API.patch('/api/v1/providers/' + this.providerId + '/models/' + this.editModelForm._id, body);
 showToast('Model updated', 'success');
 this.showEditModelModal = false;
 await this.loadModels();
 } catch (e) {
 showToast(e?.message || 'Failed to update model', 'error');
 } finally {
 this.savingModel = false;
 }
 },
 async toggleModel(id, current) {
 try {
 await API.patch('/api/v1/providers/' + this.providerId + '/models/' + id, { isEnabled: !current });
 showToast('Model ' + (!current ? 'enabled' : 'disabled'), !current ? 'success' : 'warning');
 await this.loadModels();
 } catch (e) {
 showToast(e?.message || 'Failed to update model', 'error');
 }
 },
 async deleteModel(id, name) {
 if (!(await confirmDialog({ title: 'Delete Model', message: 'Delete model "' + name + '"? This cannot be undone.', confirmText: 'Delete', danger: true }))) return;
 try {
 await API.del('/api/v1/providers/' + this.providerId + '/models/' + id);
 showToast('Model deleted', 'success');
 await this.loadModels();
 } catch (e) {
 showToast(e?.message || 'Failed to delete model', 'error');
 }
 }
 };
}
</script>
</body>
</html>
